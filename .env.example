# Mistral API — get from https://console.mistral.ai
# Used for both chat (LLM routing, answering, rewriting) and embeddings
MISTRAL_API_KEY=your_mistral_api_key_here

# ChromaDB local persistence directory
CHROMA_PERSIST_DIR=./data/chroma_db

# BM25 index file path (pickle)
BM25_INDEX_PATH=./data/bm25_index.pkl

# Corpus metadata JSON (chunk_id → metadata mapping)
CORPUS_METADATA_PATH=./data/corpus_metadata.json

# Traces output directory
TRACES_DIR=./traces

# Episodic memory JSONL log
EPISODIC_LOG_PATH=./data/episodic_memory.jsonl

# Semantic memory SQLite database
SEMANTIC_DB_PATH=./data/semantic_memory.db

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
